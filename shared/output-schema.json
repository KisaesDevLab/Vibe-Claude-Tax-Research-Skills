{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KisaesDevLab/vibe-claude-tax-research-skills/shared/output-schema.json",
  "title": "Vibe CPA Skill Output Sidecar",
  "type": "object",
  "required": ["skill", "version", "generated_at", "task", "conclusion",
               "confidence_band", "authorities", "verification_checklist"],
  "properties": {
    "skill": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "generated_at": { "type": "string", "format": "date-time" },
    "task": {
      "type": "object",
      "required": ["intake", "issue"],
      "properties": {
        "intake": { "type": "object" },
        "issue": { "type": "string" },
        "taxpayer_circuit": { "type": "string" },
        "taxpayer_state": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "tax_year": { "type": "integer" },
        "engagement_state": { "type": "string", "pattern": "^[A-Z]{2}$",
          "description": "Phase 9: state of the CPA engagement (for state-board overlay on AICPA-code skill, FTC Safeguards triggers, etc.)" },
        "entity_type": { "type": "string",
          "description": "Phase 9: nonissuer | issuer | governmental | nonprofit (drives PCAOB / GASB / GAGAS routing)" }
      }
    },
    "analysis": { "type": "string" },
    "conclusion": { "type": "string" },
    "confidence_band": {
      "type": "string",
      "enum": ["HIGH", "MODERATE", "LOW", "SPECULATIVE"]
    },
    "band_rationale": { "type": "string" },
    "disclosure_recommended": { "type": "boolean" },
    "penalty_exposure": { "type": "string" },
    "authorities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["authority_type", "citation", "url",
                     "retrieved_date", "quoted_text", "weight"],
        "properties": {
          "authority_domain": {
            "type": "string",
            "enum": ["tax_position", "professional_conduct", "gaap"],
            "default": "tax_position",
            "description": "Phase 9: which authority hierarchy applies. tax_position uses the §1.6662-4(d)(3) ladder (default; backward compatible). professional_conduct uses the AICPA / state-board ladder. gaap uses the FASB ASC 105-10 two-tier scheme. Cross-domain citations (e.g., ASC 740 cited in a tax memo) stay in tax_position with weight persuasive_non_authority."
          },
          "authority_type": {
            "type": "string",
            "enum": [
              "IRC", "TreasReg", "TreasuryDecision", "StatutesAtLarge",
              "RevRul", "RevProc", "Notice", "Announcement",
              "PLR", "TAM", "CCA", "GCM", "AOD", "FSA",
              "OfficeMemo", "InfoLetter",
              "IRSPub", "IRM", "ATG", "ISPPaper", "IRSNewsRelease",
              "JCT_BlueBook", "LegHistory", "Greenbook", "CBOReport",
              "SCOTUS", "CtAppeals", "TaxCt", "DistCt", "CtFedClaims",
              "StateStatute", "StateReg", "StateAdmin", "StateCt",
              "Treaty", "Form", "Instructions",
              "AICPA_Code", "AICPA_SSARS", "AICPA_SAS", "AICPA_SSAE",
              "AICPA_SQMS", "AICPA_PracticeAid", "AICPA_TPA",
              "FASB_ASC", "FASB_ASU", "FASB_Concepts", "EITF",
              "StateBoardRule"
            ]
          },
          "citation": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "retrieved_date": { "type": "string", "format": "date" },
          "quoted_text": { "type": "string", "maxLength": 600 },
          "pin_cite": { "type": "string" },
          "weight": {
            "type": "string",
            "enum": ["primary_statute", "binding_judicial", "regulation",
                     "binding_circuit", "judicial", "irs_published",
                     "legislative_history", "written_determinations",
                     "persuasive_non_authority", "not_authority",
                     "binding_on_member", "interpretive", "practice_aid",
                     "gaap_codified", "gaap_pre_codification_grandfathered",
                     "gaap_non_authoritative"]
          },
          "weight_override_rationale": { "type": "string" },
          "chevron_replaced": { "type": "boolean" }
        }
      }
    },
    "public_laws_consulted": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["public_law", "popular_name"],
        "properties": {
          "public_law": { "type": "string" },
          "popular_name": { "type": "string" },
          "classification_tables_url": { "type": "string", "format": "uri" },
          "affected_irc_sections": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "state_files_consulted": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state_code", "skill", "status"],
        "properties": {
          "state_code": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "skill": { "type": "string" },
          "status": { "type": "string", "enum": ["stub", "draft", "reviewed", "verified"] },
          "last_reviewed": { "type": "string", "format": "date" }
        }
      }
    },
    "unresolved_citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposition", "search", "date"],
        "properties": {
          "proposition": { "type": "string" },
          "search": { "type": "string" },
          "date": { "type": "string", "format": "date" }
        }
      }
    },
    "staleness_warnings": { "type": "array", "items": { "type": "string" } },
    "negative_treatment_review_required": {
      "type": "boolean",
      "description": "True for high-stakes positions; flags the residual practitioner responsibility for citator check (free-source pack cannot detect implicit overrules)"
    },
    "state_overlay_required": {
      "type": "boolean",
      "description": "Phase 9: true when a state board of accountancy rule is stricter than the AICPA Code on the matter at hand (e.g., CA / NY / TX independence overlays)."
    },
    "legal_review_required": {
      "type": "boolean",
      "description": "Phase 9: true when output is a template framework (e.g., engagement letter language) that must be reviewed by firm counsel before client use."
    },
    "verification_checklist": {
      "type": "object",
      "description": "Tax-position checklist (SSTS / Circular 230). Required keys are conditionally enforced when authority_domain includes tax_position; legacy skills always emit them. New AICPA / engagement / GAAP skills may omit these and emit a sibling checklist instead.",
      "additionalProperties": { "type": "boolean" }
    },
    "verification_checklist_aicpa_code": {
      "type": "object",
      "description": "Phase 9: AICPA Code of Professional Conduct module — independence threats identified, safeguards documented, conflicts disclosed, confidentiality clause active, §1.295 nonattest scope confirmed.",
      "additionalProperties": { "type": "boolean" }
    },
    "verification_checklist_engagement": {
      "type": "object",
      "description": "Phase 9: engagement-letter required-elements module — required AR-C / AU-C / AT-C / Tax practice-aid elements present, signed by both parties, scope clear, fee arrangement disclosed, FTC Safeguards Rule clause present where applicable.",
      "additionalProperties": { "type": "boolean" }
    },
    "verification_checklist_gaap": {
      "type": "object",
      "description": "Phase 9: GAAP research module — ASC topic confirmed, ASUs through effective date verified, disclosure requirements identified, non-authoritative sources flagged.",
      "additionalProperties": { "type": "boolean" }
    },
    "disclosure_forms": {
      "type": "array",
      "items": { "enum": ["8275", "8275-R", "8886", "none"] }
    }
  }
}
